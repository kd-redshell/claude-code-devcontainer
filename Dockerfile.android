# Android Development Profile
# Extends the base Claude Code devcontainer with Android SDK/NDK/emulator.
#
# Requires the base image to be built and tagged first:
#   docker build -t claude-devcontainer-base:latest -f Dockerfile .
#   docker build -f Dockerfile.android .
#
# Or via the devc CLI:
#   devc . --target android

ARG BASE_IMAGE=claude-devcontainer-base:latest
FROM ${BASE_IMAGE}

# Configurable SDK versions — override via .devcontainer/env
ARG ANDROID_API=34
ARG ANDROID_BUILD_TOOLS=34.0.0
ARG ANDROID_NDK=27.0.12077973

USER root

# ── System packages for Android Java + NDK development ──────────────
# Packages already in the base image (build-essential, git, curl, unzip)
# are not repeated here.
# `universe` is already enabled on the base image; this re-enables it
# defensively in case the base ever ships without it.
RUN apt-get update \
 && apt-get install -y --no-install-recommends software-properties-common \
 && add-apt-repository universe \
 && apt-get update \
 && apt-get install -y --no-install-recommends \
    # JDK
    openjdk-17-jdk \
    # Utilities not in base
    wget \
    # NDK / native compilation
    cmake \
    ninja-build \
    gcc-multilib \
    g++-multilib \
    libc6-dev-i386 \
    # 32-bit & system libs needed by SDK/NDK toolchains
    lib32z1 \
    lib32stdc++6 \
    libncurses6 \
    libgl1-mesa-dev \
    # Software GLES/EGL + Mesa software rasterizer for headless GL rendering
    libegl1 \
    libgles2 \
    libgl1-mesa-dri \
    # Emulator dependencies
    libpulse0 \
    libxcomposite1 \
    libxcursor1 \
    libxi6 \
    libxtst6 \
    libnss3 \
    libxrandr2 \
    libxdamage1 \
    libxfixes3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libgbm1 \
    libpango-1.0-0 \
    libcairo2 \
 && rm -rf /var/lib/apt/lists/*

# ── Environment ──────────────────────────────────────────────────────
ENV ANDROID_HOME=/opt/android-sdk
ENV ANDROID_SDK_ROOT=${ANDROID_HOME}
ENV PATH="${ANDROID_HOME}/cmdline-tools/latest/bin:${ANDROID_HOME}/platform-tools:${ANDROID_HOME}/emulator:${PATH}"

# ── Android SDK command-line tools ───────────────────────────────────
# Check https://developer.android.com/studio#command-line-tools-only for the latest URL
ARG CMDLINE_TOOLS_URL=https://dl.google.com/android/repository/commandlinetools-linux-11076708_latest.zip

RUN mkdir -p ${ANDROID_HOME}/cmdline-tools \
 && cd ${ANDROID_HOME}/cmdline-tools \
 && wget -q "${CMDLINE_TOOLS_URL}" -O cmdline-tools.zip \
 && unzip -q cmdline-tools.zip \
 && mv cmdline-tools latest \
 && rm cmdline-tools.zip

# ── Accept licences & install SDK components ─────────────────────────
# Split into separate RUN commands so BuildKit commits each layer before
# starting the next download — keeps peak memory below the OOM threshold.
RUN bash -c 'yes 2>/dev/null | sdkmanager --licenses > /dev/null 2>&1 || true' \
 && sdkmanager --update \
 && sdkmanager "platform-tools" "build-tools;${ANDROID_BUILD_TOOLS}" "platforms;android-${ANDROID_API}" "cmake;3.22.1" \
 && rm -rf /tmp/* /var/tmp/*

RUN sdkmanager "ndk;${ANDROID_NDK}" \
 && rm -rf /tmp/* /var/tmp/*

# No local `emulator` package or `system-images` here: emulation runs in a
# remote MCP server. This container only interfaces with Android targets
# (remote-emulated or physical) via adb/appium/mitmproxy/frida, and builds.

# ── User-level tools ────────────────────────────────────────────────
USER vscode

# Appium via fnm's Node (already installed in base image)
RUN eval "$($FNM_DIR/fnm env)" && npm install -g appium

# Android-specific Python tools (avd-vr-emulator skill)
RUN uv tool install mitmproxy
RUN uv tool install frida-tools
